# MedFlow Environment Configuration
# Copy this file to .env and fill in your values.
# Run infrastructure/deploy_all.sh to provision all AWS resources —
# it will populate most of these automatically.

# ============================================================
# AWS Configuration
# ============================================================
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=                        # your 12-digit AWS account ID

# ============================================================
# AgentCore Runtime
# ============================================================
AGENTCORE_RUNTIME_ROLE_ARN=            # arn:aws:iam::<account>:role/MedFlowAgentCoreRuntimeRole
AGENTCORE_EXECUTION_TIMEOUT=28800

# AgentCore Memory (created by deploy_all.sh)
AGENTCORE_MEMORY_ID=

# AgentCore Gateway (created by deploy_all.sh)
AGENTCORE_GATEWAY_ID=
AGENTCORE_GATEWAY_URL=                 # https://<gateway-id>.gateway.bedrock-agentcore.<region>.amazonaws.com/mcp

# AgentCore Runtime agents — populated after: agentcore launch (one per agent)
AGENTCORE_ELIGIBILITY_RUNTIME_ARN=
AGENTCORE_ADVERSE_EVENT_RUNTIME_ARN=
AGENTCORE_INSURANCE_AUTH_RUNTIME_ARN=

# ============================================================
# Verified Permissions (Cedar policies)
# ============================================================
VERIFIED_PERMISSIONS_POLICY_STORE_ID=  # created by infrastructure/setup_verified_permissions.py

# ============================================================
# Bedrock Configuration
# ============================================================
BEDROCK_KNOWLEDGE_BASE_ID=             # populated by deploy_all.sh after KB creation
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20251022-v2:0
OPENSEARCH_COLLECTION_ID=             # alphanumeric ID from OpenSearch Serverless console

# ============================================================
# Lambda Functions (deployed by deploy_all.sh)
# ============================================================
LAMBDA_PDF_GENERATOR_ARN=              # arn:aws:lambda:<region>:<account>:function:medflow-pdf-generator
LAMBDA_EHR_MOCK_ARN=                   # arn:aws:lambda:<region>:<account>:function:medflow-ehr-mock-api

# ============================================================
# S3 Buckets (created by deploy_all.sh)
# ============================================================
S3_GENERATED_REPORTS_BUCKET=           # medflow-generated-reports-<account>
S3_TRIAL_DATA_BUCKET=
S3_KNOWLEDGE_BASE_BUCKET=             # medflow-knowledge-base-<account>

# ============================================================
# Logging & Application
# ============================================================
CLOUDWATCH_LOG_LEVEL=INFO
CLOUDWATCH_ENABLED=true
ENVIRONMENT=demo
DEBUG=false
